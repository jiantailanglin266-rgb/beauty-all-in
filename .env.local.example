# ============================================================
# BEAUTY ALL IN 環境変数サンプル
# このファイルを .env.local にコピーして値を設定してください
#   cp .env.local.example .env.local
# ============================================================

# --- サイトURL（本番の公開URL。OGP・sitemap・canonical に使用） ---
NEXT_PUBLIC_SITE_URL=https://beauty-all-in.example.com

# --- Google Analytics 4 測定ID（例: G-XXXXXXXXXX）。空なら計測タグは出力されません ---
NEXT_PUBLIC_GA_ID=

# --- Google Tag Manager コンテナID（例: GTM-XXXXXXX）。空なら GTM は出力されません ---
NEXT_PUBLIC_GTM_ID=

# --- お問い合わせフォームの送信先メールアドレス（サーバー側で使用） ---
CONTACT_TO_EMAIL=info@example.com

# --- （任意）フォーム送信をメール送信サービスに接続する場合のAPIキーなど ---
# 例: Resend / SendGrid など。未設定の場合はサーバーログに出力するモックとして動作します。
# RESEND_API_KEY=
